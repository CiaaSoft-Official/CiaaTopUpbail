    "test:watch": "mocha --watch",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.56.0",
    "@typescript-eslint/rule-tester": "^8.56.0",
    "eslint": "^10.0.0",
    "eslint-plugin-eslint-plugin": "^7.3.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mocha": "^11.7.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "eslint": ">=10.0.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix"
